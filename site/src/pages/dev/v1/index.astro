<script>
  // Mobile nav toggle
  document.getElementById('navToggle')?.addEventListener('click', () => {
    document.getElementById('navLinks')?.classList.toggle('nav__links--open');
    document.getElementById('navToggle')?.classList.toggle('nav__toggle--open');
  });

  // Close mobile nav on link click
  document.querySelectorAll('.nav__links a').forEach(link => {
    link.addEventListener('click', () => {
      document.getElementById('navLinks')?.classList.remove('nav__links--open');
      document.getElementById('navToggle')?.classList.remove('nav__toggle--open');
    });
  });

  // Sticky nav background on scroll
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      nav?.classList.add('nav--scrolled');
    } else {
      nav?.classList.remove('nav--scrolled');
    }
  });

  // Scroll-triggered reveal animations
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -60px 0px' });

  document.querySelectorAll('.tour-card, .contact__card, .about__text, .about__portrait, .tour-category__title, .section-header').forEach(el => {
    el.classList.add('reveal');
    observer.observe(el);
  });
</script>

<style>
  /* ===================================================
     CSS CUSTOM PROPERTIES
     =================================================== */
  :root {
    --color-bg-primary: #0a0a0a;
    --color-bg-secondary: #111111;
    --color-bg-tertiary: #1a1a1a;
    --color-bg-card: #141414;
    --color-bg-card-hover: #1c1c1c;

    --color-gold: #d4af37;
    --color-gold-dark: #c5a028;
    --color-gold-light: #e8d48b;
    --color-gold-pale: #f5ecd0;
    --color-gold-glow: rgba(212, 175, 55, 0.15);

    --color-burgundy: #5c1a2a;
    --color-burgundy-deep: #3d1018;
    --color-burgundy-glow: rgba(92, 26, 42, 0.3);

    --color-text-primary: #e8e0d0;
    --color-text-secondary: #a89e8c;
    --color-text-muted: #6b6356;

    --color-border: rgba(212, 175, 55, 0.15);
    --color-border-strong: rgba(212, 175, 55, 0.3);

    --font-heading: 'Cormorant Garamond', 'Georgia', serif;
    --font-body: 'EB Garamond', 'Georgia', serif;

    --space-xs: 0.5rem;
    --space-sm: 1rem;
    --space-md: 2rem;
    --space-lg: 4rem;
    --space-xl: 6rem;
    --space-2xl: 8rem;

    --transition-base: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    --transition-slow: 0.6s cubic-bezier(0.4, 0, 0.2, 1);

    --container-width: 1200px;
    --nav-height: 72px;
  }

  /* ===================================================
     RESET & BASE
     =================================================== */
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    scroll-padding-top: var(--nav-height);
  }

  body {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.7;
    color: var(--color-text-primary);
    background-color: var(--color-bg-primary);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  /* Subtle noise texture overlay on body */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
  }

  a {
    color: var(--color-gold);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  a:hover {
    color: var(--color-gold-light);
  }

  img {
    max-width: 100%;
    display: block;
  }

  .container {
    max-width: var(--container-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  /* ===================================================
     REVEAL ANIMATIONS
     =================================================== */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1), transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .reveal.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* Staggered card reveals */
  .tour-card.reveal:nth-child(1) { transition-delay: 0s; }
  .tour-card.reveal:nth-child(2) { transition-delay: 0.1s; }
  .tour-card.reveal:nth-child(3) { transition-delay: 0.2s; }
  .tour-card.reveal:nth-child(4) { transition-delay: 0.3s; }
  .tour-card.reveal:nth-child(5) { transition-delay: 0.4s; }
  .tour-card.reveal:nth-child(6) { transition-delay: 0.5s; }
  .tour-card.reveal:nth-child(7) { transition-delay: 0.6s; }
  .tour-card.reveal:nth-child(8) { transition-delay: 0.7s; }

  .contact__card.reveal:nth-child(1) { transition-delay: 0s; }
  .contact__card.reveal:nth-child(2) { transition-delay: 0.12s; }
  .contact__card.reveal:nth-child(3) { transition-delay: 0.24s; }
  .contact__card.reveal:nth-child(4) { transition-delay: 0.36s; }

  /* ===================================================
     SECTION HEADER
     =================================================== */
  .section-header {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .section-header__ornament {
    display: block;
    font-size: 1.5rem;
    color: var(--color-gold);
    margin-bottom: var(--space-sm);
    opacity: 0.7;
  }

  .section-header__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 300;
    color: var(--color-gold);
    letter-spacing: 0.05em;
    line-height: 1.2;
  }

  .section-header__rule {
    width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold), transparent);
    margin: var(--space-sm) auto;
  }

  .section-header__subtitle {
    font-family: var(--font-body);
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    font-style: italic;
    margin-top: var(--space-xs);
  }

  /* ===================================================
     NAVIGATION
     =================================================== */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    height: var(--nav-height);
    transition: background var(--transition-base), box-shadow var(--transition-base), backdrop-filter var(--transition-base);
  }

  .nav--scrolled {
    background: rgba(10, 10, 10, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 1px 0 var(--color-border);
  }

  .nav__inner {
    max-width: var(--container-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav__logo {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--color-gold) !important;
    letter-spacing: 0.15em;
    position: relative;
  }

  .nav__logo::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--color-gold);
    opacity: 0.4;
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    list-style: none;
  }

  .nav__links a {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    position: relative;
    padding: 4px 0;
  }

  .nav__links a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--color-gold);
    transition: width var(--transition-base);
  }

  .nav__links a:hover {
    color: var(--color-gold-light);
  }

  .nav__links a:hover::after {
    width: 100%;
  }

  .nav__cta {
    border: 1px solid var(--color-gold) !important;
    padding: 8px 20px !important;
    color: var(--color-gold) !important;
    transition: all var(--transition-base) !important;
  }

  .nav__cta:hover {
    background: var(--color-gold) !important;
    color: var(--color-bg-primary) !important;
  }

  .nav__cta::after {
    display: none !important;
  }

  /* Mobile toggle */
  .nav__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav__toggle span {
    display: block;
    width: 24px;
    height: 1.5px;
    background: var(--color-gold);
    transition: all var(--transition-base);
    transform-origin: center;
  }

  .nav__toggle--open span:nth-child(1) {
    transform: rotate(45deg) translate(4.5px, 4.5px);
  }
  .nav__toggle--open span:nth-child(2) {
    opacity: 0;
  }
  .nav__toggle--open span:nth-child(3) {
    transform: rotate(-45deg) translate(4.5px, -4.5px);
  }

  /* ===================================================
     HERO
     =================================================== */
  .hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero__gallery {
    position: absolute;
    inset: 0;
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    animation: heroFade 25s infinite;
    background-size: cover;
    background-position: center;
  }

  /* Slide 1: Warm Amalfi sunset over the sea */
  .hero__slide--1 {
    background:
      radial-gradient(ellipse at 30% 80%, rgba(212, 175, 55, 0.2) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 20%, rgba(92, 26, 42, 0.4) 0%, transparent 60%),
      linear-gradient(175deg,
        #1a0a0a 0%,
        #2d1520 15%,
        #5c1a2a 30%,
        #8b3a1a 45%,
        #d4af37 55%,
        #e8d48b 60%,
        #4a7c8a 70%,
        #1a3a4a 85%,
        #0a1520 100%
      );
    animation-delay: 0s;
  }

  /* Slide 2: Deep blue Mediterranean with golden light */
  .hero__slide--2 {
    background:
      radial-gradient(ellipse at 50% 90%, rgba(212, 175, 55, 0.15) 0%, transparent 40%),
      radial-gradient(ellipse at 80% 30%, rgba(30, 60, 90, 0.6) 0%, transparent 50%),
      linear-gradient(170deg,
        #0a0a1a 0%,
        #0d1a2d 20%,
        #1a3a5c 35%,
        #2a5a7a 48%,
        #3a7a9a 55%,
        #1a4a6a 65%,
        #0d2a4a 78%,
        #0a1525 90%,
        #050a10 100%
      );
    animation-delay: 5s;
  }

  /* Slide 3: Ancient stone textures - Pompeii warmth */
  .hero__slide--3 {
    background:
      radial-gradient(ellipse at 40% 50%, rgba(180, 140, 80, 0.3) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 70%, rgba(120, 70, 40, 0.4) 0%, transparent 40%),
      linear-gradient(160deg,
        #1a1510 0%,
        #2d2218 15%,
        #4a3828 30%,
        #6b5238 42%,
        #8b6a40 52%,
        #a08050 58%,
        #7a5a35 68%,
        #4a3520 80%,
        #1a1510 100%
      );
    animation-delay: 10s;
  }

  /* Slide 4: Lemon grove greens with golden accents */
  .hero__slide--4 {
    background:
      radial-gradient(ellipse at 60% 40%, rgba(180, 200, 60, 0.15) 0%, transparent 40%),
      radial-gradient(ellipse at 30% 70%, rgba(212, 175, 55, 0.2) 0%, transparent 40%),
      linear-gradient(165deg,
        #0a0f08 0%,
        #142010 18%,
        #1e3518 32%,
        #2a4a20 45%,
        #3a5a28 52%,
        #4a6a30 56%,
        #3a5520 65%,
        #1e3518 78%,
        #0a1508 90%,
        #050a04 100%
      );
    animation-delay: 15s;
  }

  /* Slide 5: Twilight violet and rose over coast */
  .hero__slide--5 {
    background:
      radial-gradient(ellipse at 50% 60%, rgba(150, 100, 140, 0.25) 0%, transparent 45%),
      radial-gradient(ellipse at 20% 30%, rgba(92, 26, 42, 0.3) 0%, transparent 50%),
      linear-gradient(175deg,
        #0a0810 0%,
        #1a1025 18%,
        #2d1838 30%,
        #4a2050 42%,
        #5c2860 48%,
        #4a2548 55%,
        #3a1a38 65%,
        #1a1028 80%,
        #0a0810 100%
      );
    animation-delay: 20s;
  }

  @keyframes heroFade {
    0%   { opacity: 0; }
    4%   { opacity: 1; }
    20%  { opacity: 1; }
    24%  { opacity: 0; }
    100% { opacity: 0; }
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at center, rgba(10, 10, 10, 0.3) 0%, rgba(10, 10, 10, 0.7) 100%),
      linear-gradient(180deg, rgba(10, 10, 10, 0.4) 0%, transparent 30%, transparent 70%, rgba(10, 10, 10, 0.8) 100%);
  }

  .hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 var(--space-md);
    animation: heroContentIn 1.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    opacity: 0;
  }

  @keyframes heroContentIn {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero__ornament {
    font-size: 2rem;
    color: var(--color-gold);
    opacity: 0.6;
    margin-bottom: var(--space-sm);
    animation: heroOrnamentPulse 3s ease-in-out infinite;
  }

  @keyframes heroOrnamentPulse {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.1); }
  }

  .hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 6vw, 5rem);
    font-weight: 300;
    color: var(--color-gold);
    letter-spacing: 0.08em;
    line-height: 1.1;
    text-shadow: 0 2px 40px rgba(212, 175, 55, 0.3);
  }

  .hero__handle {
    font-family: var(--font-body);
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    color: rgba(212, 175, 55, 0.55);
    font-style: italic;
    margin-top: 0.5rem;
  }

  .hero__divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    margin: var(--space-md) 0;
  }

  .hero__divider-line {
    display: block;
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold));
  }

  .hero__divider-line:last-child {
    background: linear-gradient(90deg, var(--color-gold), transparent);
  }

  .hero__divider-diamond {
    color: var(--color-gold);
    font-size: 0.8rem;
    opacity: 0.7;
  }

  .hero__subtitle {
    font-family: var(--font-heading);
    font-size: clamp(1.1rem, 2.5vw, 1.6rem);
    font-weight: 300;
    color: var(--color-text-primary);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1.6;
  }

  .hero__tagline {
    font-family: var(--font-body);
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.2em;
    margin-top: var(--space-xs);
    font-style: italic;
  }

  .hero__cta {
    display: inline-block;
    margin-top: var(--space-lg);
    padding: 16px 48px;
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-bg-primary);
    background: linear-gradient(135deg, var(--color-gold), var(--color-gold-dark));
    border: none;
    position: relative;
    overflow: hidden;
    transition: all var(--transition-base);
  }

  .hero__cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-gold-light), var(--color-gold));
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .hero__cta:hover {
    color: var(--color-bg-primary);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(212, 175, 55, 0.3);
  }

  .hero__cta:hover::before {
    opacity: 1;
  }

  .hero__cta span,
  .hero__cta {
    position: relative;
    z-index: 1;
  }

  .hero__scroll-hint {
    position: absolute;
    bottom: var(--space-md);
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    animation: scrollBounce 2s ease-in-out infinite;
  }

  .hero__scroll-hint span {
    font-size: 1.5rem;
    color: var(--color-gold);
    opacity: 0.5;
  }

  @keyframes scrollBounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  /* ===================================================
     ABOUT
     =================================================== */
  .about {
    padding: var(--space-2xl) 0;
    background: var(--color-bg-secondary);
    position: relative;
  }

  .about::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border-strong), transparent);
  }

  .about__grid {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: var(--space-lg);
    align-items: start;
  }

  .about__portrait-frame {
    aspect-ratio: 3 / 4;
    border: 1px solid var(--color-border-strong);
    padding: 8px;
    position: relative;
  }

  .about__portrait-frame::before {
    content: '';
    position: absolute;
    inset: -4px;
    border: 1px solid var(--color-border);
  }

  .about__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about__name {
    font-family: var(--font-heading);
    font-size: 2.4rem;
    font-weight: 400;
    color: var(--color-gold);
    letter-spacing: 0.04em;
    margin-bottom: 4px;
  }

  .about__title-role {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 400;
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border);
  }

  .about__bio {
    color: var(--color-text-primary);
    margin-bottom: var(--space-sm);
    font-size: 1.05rem;
  }

  .about__bio:last-of-type {
    margin-bottom: var(--space-md);
  }

  .about__credentials {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  .about__credential {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.95rem;
    color: var(--color-text-secondary);
  }

  .about__credential-icon {
    font-size: 1.2rem;
    min-width: 24px;
  }

  /* ===================================================
     TOURS
     =================================================== */
  .tours {
    padding: var(--space-2xl) 0;
    background: var(--color-bg-primary);
    position: relative;
  }

  .tour-category {
    margin-bottom: var(--space-xl);
  }

  .tour-category:last-child {
    margin-bottom: 0;
  }

  .tour-category__title {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 400;
    color: var(--color-gold);
    letter-spacing: 0.06em;
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .tour-category__emoji {
    font-size: 1.4rem;
  }

  .tour-category__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  /* ===================================================
     TOUR CARD
     =================================================== */
  .tour-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  /* --- Tour Card Image (Museum Frame) --- */
  .tour-card__image-wrap {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border-bottom: 2px solid var(--color-border);
    box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.5);
    /* Double border frame effect */
    outline: 1px solid rgba(212, 175, 55, 0.25);
    outline-offset: -6px;
  }

  .tour-card__image-wrap::before {
    content: '';
    position: absolute;
    inset: 3px;
    border: 1px solid rgba(212, 175, 55, 0.15);
    z-index: 2;
    pointer-events: none;
  }

  .tour-card__image-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(212, 175, 55, 0) 0%, rgba(212, 175, 55, 0.15) 100%);
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 3;
    pointer-events: none;
  }

  .tour-card:hover .tour-card__image-wrap::after {
    opacity: 1;
  }

  .tour-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }

  .tour-card:hover .tour-card__image {
    transform: scale(1.06);
  }

  .tour-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-gold), transparent);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .tour-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 60%, var(--color-gold-glow) 100%);
    opacity: 0;
    transition: opacity var(--transition-base);
    pointer-events: none;
  }

  .tour-card:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4), 0 0 0 1px var(--color-border);
  }

  .tour-card:hover::before,
  .tour-card:hover::after {
    opacity: 1;
  }

  .tour-card__header {
    padding: var(--space-md) var(--space-md) var(--space-sm);
    border-bottom: 1px solid var(--color-border);
  }

  .tour-card__title {
    font-family: var(--font-heading);
    font-size: 1.45rem;
    font-weight: 500;
    color: var(--color-gold);
    letter-spacing: 0.03em;
    line-height: 1.3;
    margin-bottom: 4px;
  }

  .tour-card__subtitle {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .tour-card__body {
    padding: var(--space-sm) var(--space-md);
    flex: 1;
  }

  .tour-card__description {
    font-size: 0.98rem;
    color: var(--color-text-primary);
    line-height: 1.65;
  }

  .tour-card__details {
    margin-top: var(--space-sm);
    padding-left: var(--space-sm);
    list-style: none;
  }

  .tour-card__details li {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    padding: 2px 0;
    position: relative;
    padding-left: var(--space-sm);
  }

  .tour-card__details li::before {
    content: '\2022';
    position: absolute;
    left: 0;
    color: var(--color-gold);
    opacity: 0.6;
  }

  .tour-card__extras {
    margin-top: var(--space-sm);
    font-size: 0.9rem;
    color: var(--color-gold-light);
    font-style: italic;
    opacity: 0.8;
  }

  .tour-card__footer {
    padding: var(--space-sm) var(--space-md) var(--space-md);
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
