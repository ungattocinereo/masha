---
import { tours, categories, about, contacts } from '../../../data/tours';

const toursByCategory = categories.map(cat => ({
  ...cat,
  tours: tours.filter(t => t.category === cat.id),
}));
---

<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Маша Шишкова — Лицензированный гид по Амальфитанскому побережью</title>
  <meta name="description" content="Авторские экскурсии по Неаполю, Помпеям, Геркулануму и Амальфитанскому побережью. Лицензированный гид Маша Шишкова." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet" />
</head>
<body>

<!-- ========== NAVIGATION ========== -->
<nav class="nav" id="nav">
  <div class="nav__inner">
    <a href="#hero" class="nav__logo">МШ</a>
    <button class="nav__toggle" aria-label="Меню" id="navToggle">
      <span></span><span></span><span></span>
    </button>
    <ul class="nav__links" id="navLinks">
      <li><a href="#about">О себе</a></li>
      <li><a href="#tours">Экскурсии</a></li>
      <li><a href="#contact">Контакты</a></li>
      <li><a href="#form" class="nav__cta">Записаться</a></li>
    </ul>
  </div>
</nav>

<!-- ========== HERO ========== -->
<section class="hero" id="hero">
  <div class="hero__gallery">
    <div class="hero__slide hero__slide--1"></div>
    <div class="hero__slide hero__slide--2"></div>
    <div class="hero__slide hero__slide--3"></div>
    <div class="hero__slide hero__slide--4"></div>
    <div class="hero__slide hero__slide--5"></div>
  </div>
  <div class="hero__overlay"></div>
  <div class="hero__content">
    <div class="hero__ornament">&#10022;</div>
    <h1 class="hero__title">Маша Шишкова</h1>
    <p class="hero__handle">/masha_italianskii_cocktail/</p>
    <div class="hero__divider">
      <span class="hero__divider-line"></span>
      <span class="hero__divider-diamond">&#9830;</span>
      <span class="hero__divider-line"></span>
    </div>
    <p class="hero__subtitle">Лицензированный гид<br />по Амальфитанскому побережью</p>
    <p class="hero__tagline">Неаполь &middot; Помпеи &middot; Амальфи &middot; Капри</p>
    <a href="#tours" class="hero__cta">Выбрать экскурсию</a>
  </div>
  <div class="hero__scroll-hint">
    <span>&#8595;</span>
  </div>
</section>

<!-- ========== ABOUT ========== -->
<section class="about" id="about">
  <div class="container">
    <div class="section-header">
      <span class="section-header__ornament">&#10022;</span>
      <h2 class="section-header__title">О вашем гиде</h2>
      <div class="section-header__rule"></div>
    </div>
    <div class="about__grid">
      <div class="about__portrait">
        <div class="about__portrait-frame">
          <img src="/images/masha.jpg" alt="Маша Шишкова" class="about__photo" />
        </div>
      </div>
      <div class="about__text">
        <h3 class="about__name">{about.name}</h3>
        <p class="about__title-role">{about.title}</p>
        {about.bio.map((paragraph) => (
          <p class="about__bio">{paragraph}</p>
        ))}
        <div class="about__credentials">
          <div class="about__credential">
            <span class="about__credential-icon">&#127891;</span>
            <span>{about.education}</span>
          </div>
          <div class="about__credential">
            <span class="about__credential-icon">&#128205;</span>
            <span>{about.location}</span>
          </div>
          <div class="about__credential">
            <span class="about__credential-icon">&#128220;</span>
            <span>Лицензия Regione Campania</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ========== TOURS ========== -->
<section class="tours" id="tours">
  <div class="container">
    <div class="section-header">
      <span class="section-header__ornament">&#10022;</span>
      <h2 class="section-header__title">Экскурсии и туры</h2>
      <div class="section-header__rule"></div>
      <p class="section-header__subtitle">Авторские маршруты по самым красивым местам Кампании</p>
    </div>

    {toursByCategory.map((cat) => (
      <div class="tour-category" id={`cat-${cat.id}`}>
        <h3 class="tour-category__title">
          <span class="tour-category__emoji">{cat.emoji}</span>
          {cat.name}
        </h3>
        <div class="tour-category__grid">
          {cat.tours.map((tour) => (
            <article class="tour-card">
              {tour.image && (
                <div class="tour-card__image-wrap">
                  <img src={tour.image} alt={tour.title} class="tour-card__image" loading="lazy" />
                </div>
              )}
              <div class="tour-card__header">
                <h4 class="tour-card__title">{tour.title}</h4>
                <p class="tour-card__subtitle">{tour.subtitle}</p>
              </div>
              <div class="tour-card__body">
                <p class="tour-card__description">{tour.description}</p>
                {tour.details && (
                  <ul class="tour-card__details">
                    {tour.details.map((d) => (
                      <li>{d}</li>
                    ))}
                  </ul>
                )}
                {tour.extras && (
                  <p class="tour-card__extras">{tour.extras}</p>
                )}
              </div>
              <div class="tour-card__footer">
                <div class="tour-card__meta">
                  <span class="tour-card__duration">&#9202; {tour.duration}</span>
                  {tour.maxPeople && <span class="tour-card__people">&#128101; {tour.maxPeople}</span>}
                </div>
                <div class="tour-card__price">{tour.price}</div>
              </div>
            </article>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<!-- ========== CONTACT ========== -->
<section class="contact" id="contact">
