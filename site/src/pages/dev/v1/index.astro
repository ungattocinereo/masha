</section>

<!-- ========== FORM ========== -->
<section class="form-section" id="form">
  <div class="container">
    <div class="section-header">
      <span class="section-header__ornament">&#10022;</span>
      <h2 class="section-header__title">Записаться на экскурсию</h2>
      <div class="section-header__rule"></div>
      <p class="section-header__subtitle">Заполните форму и я свяжусь с вами в течение 24 часов</p>
    </div>
    <form class="booking-form" action="#" method="POST">
      <div class="booking-form__grid">
        <div class="booking-form__field">
          <label for="name">Имя</label>
          <input type="text" id="name" name="name" placeholder="Ваше имя" required />
        </div>
        <div class="booking-form__field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="your@email.com" required />
        </div>
        <div class="booking-form__field booking-form__field--full">
          <label for="tour">Предпочтительная экскурсия</label>
          <select id="tour" name="tour">
            <option value="">Выберите экскурсию...</option>
            {tours.map((tour) => (
              <option value={tour.id}>{tour.title} — {tour.price}</option>
            ))}
          </select>
        </div>
        <div class="booking-form__field booking-form__field--full">
          <label for="message">Сообщение</label>
          <textarea id="message" name="message" rows="5" placeholder="Расскажите о ваших пожеланиях: даты, количество человек, особые интересы..."></textarea>
        </div>
      </div>
      <button type="submit" class="booking-form__submit">Отправить заявку</button>
    </form>
  </div>
</section>

<!-- ========== FOOTER ========== -->
