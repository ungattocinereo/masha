---
import { tours, categories, about, contacts } from '../../../data/tours';

const toursByCategory = categories.map(cat => ({
  ...cat,
  tours: tours.filter(t => t.category === cat.id),
}));
---

<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Маша Шишкова — Гид на Амальфитанском побережье</title>
  <meta name="description" content="Авторские экскурсии по Неаполю, Помпеям, Геркулануму и Амальфитанскому побережью. Лицензированный гид Маша Шишкова." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;0,6..96,700;0,6..96,900;1,6..96,400;1,6..96,700&family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ═══════════════ FILM GRAIN OVERLAY (global) ═══════════════ -->
  <!-- handled by body::after in CSS -->

  <!-- ═══════════════ NAVIGATION ═══════════════ -->
  <nav class="nav">
    <div class="nav__inner">
      <a href="#hero" class="nav__logo">МШ</a>
      <div class="nav__links">
        <a href="#about">О гиде</a>
        <a href="#tours">Экскурсии</a>
        <a href="#contact">Контакт</a>
      </div>
    </div>
  </nav>

  <!-- ═══════════════ HERO ═══════════════ -->
  <section id="hero" class="hero">
    <div class="hero__gradient hero__gradient--1"></div>
    <div class="hero__gradient hero__gradient--2"></div>
    <div class="hero__gradient hero__gradient--3"></div>
    <div class="hero__grain"></div>
    <div class="hero__content">
      <p class="hero__overline">Амальфитанское побережье &bull; Неаполь &bull; Помпеи</p>
      <h1 class="hero__title">Маша<br/>Шишкова</h1>
      <p class="hero__handle">/masha_italianskii_cocktail/</p>
      <p class="hero__subtitle">Авторские экскурсии по самым красивым местам Италии</p>
      <p class="hero__tagline">Лицензированный гид &middot; Campania, Italia</p>
      <a href="#tours" class="hero__cta">Выбрать экскурсию</a>
    </div>
    <div class="hero__scroll-hint">
      <span>скролл</span>
      <div class="hero__scroll-line"></div>
    </div>
  </section>

  <!-- ═══════════════ ABOUT ═══════════════ -->
  <section id="about" class="about">
    <div class="about__inner">
      <div class="about__quote-col">
        <blockquote class="about__pullquote">
          &laquo;Каждая экскурсия&nbsp;&mdash; это не&nbsp;просто прогулка, а&nbsp;погружение в&nbsp;историю&raquo;
        </blockquote>
        <p class="about__location">{about.location}</p>
        <img src="/images/masha.jpg" alt="Маша Шишкова" class="about__photo" />
      </div>
      <div class="about__bio-col">
        <p class="about__label">О гиде</p>
        <h2 class="about__name">{about.name}</h2>
        <p class="about__title-role">{about.title}</p>
        {about.bio.map(p => <p class="about__text">{p}</p>)}
        <p class="about__education">{about.education}</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════ TOURS ═══════════════ -->
  <section id="tours" class="tours">
    <div class="tours__header">
      <p class="tours__label">Каталог</p>
      <h2 class="tours__heading">Экскурсии</h2>
      <p class="tours__subhead">Откройте для себя южную Италию с&nbsp;авторскими маршрутами</p>
    </div>

    {toursByCategory.map((cat, catIdx) => (
      <div class={`tours__category ${catIdx % 2 === 0 ? 'tours__category--light' : 'tours__category--dark'}`}>
        <div class="tours__category-header">
          <span class="tours__category-emoji">{cat.emoji}</span>
          <h3 class="tours__category-name">{cat.name}</h3>
          <span class="tours__category-count">{cat.tours.length} {cat.tours.length === 1 ? 'экскурсия' : cat.tours.length < 5 ? 'экскурсии' : 'экскурсий'}</span>
        </div>
        <div class="tours__carousel">
          {cat.tours.map((tour, idx) => (
            <article class={`tour-card ${idx === 0 ? 'tour-card--featured' : ''}`}>
              <img src={tour.image} alt={tour.title} class="tour-card__image" loading="lazy" />
              <div class="tour-card__overlay">
                <span class="tour-card__price">{tour.price}</span>
                <h4 class="tour-card__title">{tour.title}</h4>
                <p class="tour-card__subtitle">{tour.subtitle}</p>
                <p class="tour-card__desc">{tour.description}</p>
                <span class="tour-card__duration">{tour.duration}</span>
                <a href="#contact-form" class="tour-card__cta">Забронировать</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    ))}
  </section>

  <!-- ═══════════════ CONTACT ═══════════════ -->
  <section id="contact" class="contact">
    <div class="contact__inner">
      <div class="contact__info">
        <p class="contact__label">Связаться</p>
        <h2 class="contact__heading">Давайте<br/>спланируем<br/>ваше путешествие</h2>
        <div class="contact__links">
          <a href={`mailto:${contacts.email}`} class="contact__link">
            <span class="contact__link-label">Email</span>
            <span class="contact__link-value">{contacts.email}</span>
          </a>
          <a href={contacts.telegram} class="contact__link" target="_blank" rel="noopener">
            <span class="contact__link-label">Telegram</span>
            <span class="contact__link-value">{contacts.telegramName}</span>
          </a>
          <a href={contacts.instagram} class="contact__link" target="_blank" rel="noopener">
            <span class="contact__link-label">Instagram</span>
            <span class="contact__link-value">@masha_italianskii_cocktail</span>
          </a>
          <a href={contacts.facebook} class="contact__link" target="_blank" rel="noopener">
            <span class="contact__link-label">Facebook</span>
            <span class="contact__link-value">masha.shishkova</span>
          </a>
        </div>
      </div>

      <!-- ═══════════════ CONTACT FORM ═══════════════ -->
      <div id="contact-form" class="contact__form-wrap">
        <form class="form" action="#" method="POST">
          <p class="form__label">Заявка на экскурсию</p>
          <div class="form__field">
            <label for="name">Имя</label>
            <input type="text" id="name" name="name" required placeholder="Ваше имя" />
          </div>
          <div class="form__field">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required placeholder="email@example.com" />
          </div>
          <div class="form__field">
            <label for="tour">Экскурсия</label>
            <select id="tour" name="tour">
              <option value="">Выберите экскурсию</option>
              {tours.map(t => <option value={t.id}>{t.title}</option>)}
            </select>
          </div>
          <div class="form__field">
            <label for="message">Сообщение</label>
            <textarea id="message" name="message" rows="4" placeholder="Даты, количество человек, пожелания..."></textarea>
          </div>
          <button type="submit" class="form__submit">Отправить</button>
        </form>
      </div>
    </div>
  </section>

  <!-- ═══════════════ FOOTER ═══════════════ -->
  <footer class="footer">
    <div class="footer__inner">
      <div class="footer__brand">
        <p class="footer__name">Маша Шишкова</p>
        <p class="footer__license">Гид с лицензией Regione Campania N. XXXX/XXXX</p>
      </div>
      <div class="footer__socials">
        <a href={contacts.telegram} target="_blank" rel="noopener">Telegram</a>
        <a href={contacts.instagram} target="_blank" rel="noopener">Instagram</a>
        <a href={contacts.facebook} target="_blank" rel="noopener">Facebook</a>
        <a href={`mailto:${contacts.email}`}>Email</a>
      </div>
      <div class="footer__legal">
        <p>P.IVA: XX XXX XXX XXX</p>
        <p><a href="#">Cookie Policy</a> &middot; <a href="#">Privacy Policy</a></p>
      </div>
      <div class="footer__copy">
        <p>&copy; 2024&ndash;2026 Masha Shishkova. Tutti i diritti riservati.</p>
        <p>&copy; 2024&ndash;2026 Маша Шишкова. Все права защищены.</p>
      </div>
    </div>
  </footer>

</body>
</html>

<style is:global>
  /* ═══════════════════════════════════════════
     CSS VARIABLES & THEME
     ═══════════════════════════════════════════ */
  :root {
    --cream: #f5f0e3;
    --cream-dark: #e8e0cc;
    --warm-black: #1a1714;
    --sepia: #8b7355;
    --terracotta: #b85c38;
    --wine: #6b2d3e;
    --gold: #c9a84c;

    --ff-display: 'Bodoni Moda', 'Didot', 'Playfair Display', serif;
    --ff-body: 'Lora', 'Georgia', serif;

    --grain-opacity: 0.045;
  }

  /* ═══════════════════════════════════════════
     RESET & BASE
     ═══════════════════════════════════════════ */
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
  }

  body {
    font-family: var(--ff-body);
    background: var(--cream);
    color: var(--warm-black);
    overflow-x: hidden;
    position: relative;
  }

  /* ── Global film grain overlay ── */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    opacity: var(--grain-opacity);
    background-image:
      url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 180px;
    mix-blend-mode: multiply;
  }

  img { max-width: 100%; display: block; }
  a { color: inherit; text-decoration: none; }

  ::selection {
    background: var(--terracotta);
    color: var(--cream);
  }

  /* ═══════════════════════════════════════════
     NAVIGATION
     ═══════════════════════════════════════════ */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    border-bottom: 1px solid rgba(245, 240, 227, 0.12);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: rgba(26, 23, 20, 0.3);
    transition: background 0.4s;
  }

  .nav__inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 1rem 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav__logo {
    font-family: var(--ff-display);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--cream);
  }

  .nav__links {
    display: flex;
    gap: 2.5rem;
  }

  .nav__links a {
    font-family: var(--ff-body);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(245, 240, 227, 0.7);
    transition: color 0.3s;
  }

  .nav__links a:hover {
    color: var(--cream);
  }

  /* ═══════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════ */
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--warm-black);
  }

  /* Cinematic crossfading gradients */
  .hero__gradient {
    position: absolute;
    inset: 0;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
  }

  .hero__gradient--1 {
    background:
      radial-gradient(ellipse 80% 60% at 30% 50%, rgba(184, 92, 56, 0.5), transparent 70%),
      radial-gradient(ellipse 50% 80% at 80% 30%, rgba(201, 168, 76, 0.3), transparent 60%),
      linear-gradient(160deg, #1a1714 0%, #2a2018 40%, #3d2a1a 70%, #1a1714 100%);
    animation: heroFade 12s ease-in-out infinite;
  }

  .hero__gradient--2 {
    background:
      radial-gradient(ellipse 70% 50% at 70% 60%, rgba(107, 45, 62, 0.55), transparent 65%),
      radial-gradient(ellipse 60% 40% at 20% 70%, rgba(139, 115, 85, 0.4), transparent 60%),
      linear-gradient(200deg, #1a1714 0%, #2d1a22 50%, #1a1714 100%);
    opacity: 0;
    animation: heroFade 12s ease-in-out infinite 4s;
  }

  .hero__gradient--3 {
    background:
      radial-gradient(ellipse 90% 50% at 50% 40%, rgba(201, 168, 76, 0.4), transparent 60%),
      radial-gradient(ellipse 40% 60% at 80% 80%, rgba(184, 92, 56, 0.35), transparent 60%),
      linear-gradient(180deg, #2a2018 0%, #1a1714 50%, #2d1a22 100%);
    opacity: 0;
    animation: heroFade 12s ease-in-out infinite 8s;
  }

  @keyframes heroFade {
    0%, 100% { opacity: 0; }
    16%, 50% { opacity: 1; }
    66% { opacity: 0; }
  }

  /* Hero grain */
  .hero__grain {
    position: absolute;
    inset: 0;
    opacity: 0.08;
    background-image:
      url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 256px;
    pointer-events: none;
    mix-blend-mode: overlay;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 2rem;
  }

  .hero__overline {
    font-family: var(--ff-body);
    font-size: 0.65rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgba(245, 240, 227, 0.5);
    margin-bottom: 2rem;
  }

  .hero__title {
    font-family: var(--ff-display);
    font-weight: 900;
    font-size: clamp(2.5rem, 7vw, 6rem);
    line-height: 0.88;
    color: var(--cream);
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    text-shadow: 0 4px 60px rgba(0, 0, 0, 0.5);
  }

  .hero__handle {
    font-family: var(--ff-body);
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    color: var(--sepia);
    font-style: italic;
    opacity: 0.7;
    margin-bottom: 1.5rem;
  }

  .hero__subtitle {
    font-family: var(--ff-body);
    font-style: italic;
    font-size: clamp(0.9rem, 1.8vw, 1.25rem);
    color: rgba(245, 240, 227, 0.7);
    max-width: 36ch;
    margin: 0 auto 0.75rem;
    line-height: 1.6;
  }

  .hero__tagline {
    font-family: var(--ff-body);
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(245, 240, 227, 0.4);
    margin-bottom: 3rem;
  }

  .hero__cta {
    display: inline-block;
    font-family: var(--ff-body);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cream);
    border: 1px solid rgba(245, 240, 227, 0.35);
    padding: 1rem 2.5rem;
    transition: all 0.4s;
  }

  .hero__cta:hover {
    background: var(--cream);
    color: var(--warm-black);
    border-color: var(--cream);
  }

  .hero__scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    z-index: 2;
  }

  .hero__scroll-hint span {
    font-family: var(--ff-body);
    font-size: 0.55rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(245, 240, 227, 0.35);
  }

  .hero__scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, rgba(245, 240, 227, 0.4), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.6); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  /* ═══════════════════════════════════════════
     ABOUT
     ═══════════════════════════════════════════ */
  .about {
    padding: 8rem 2.5rem;
    background: var(--cream);
    position: relative;
  }

  .about__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .about__quote-col {
    position: sticky;
    top: 8rem;
  }

  .about__pullquote {
    font-family: var(--ff-display);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.2;
    color: var(--warm-black);
    margin-bottom: 2rem;
  }

  .about__location {
    font-family: var(--ff-body);
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--sepia);
  }

  .about__label {
    font-family: var(--ff-body);
    font-size: 0.6rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--sepia);
    margin-bottom: 1.5rem;
  }

  .about__name {
    font-family: var(--ff-display);
    font-weight: 700;
    font-size: clamp(2rem, 3.5vw, 3rem);
    margin-bottom: 0.5rem;
  }

  .about__title-role {
    font-family: var(--ff-body);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--terracotta);
    margin-bottom: 2rem;
  }

  .about__text {
    font-family: var(--ff-body);
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(26, 23, 20, 0.8);
    margin-bottom: 1rem;
  }

  .about__education {
    font-family: var(--ff-body);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sepia);
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(139, 115, 85, 0.25);
  }

  .about__photo {
    width: 100%;
    margin-top: 2.5rem;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    object-position: center 20%;
    filter: sepia(0.2) saturate(0.8) contrast(1.05) brightness(0.95);
    border: none;
    box-shadow:
      0 8px 40px rgba(26, 23, 20, 0.15),
      0 2px 12px rgba(26, 23, 20, 0.1);
    transition: filter 0.6s ease;
  }

  .about__photo:hover {
    filter: sepia(0) saturate(1) contrast(1) brightness(1);
  }

  /* ═══════════════════════════════════════════
     TOURS
     ═══════════════════════════════════════════ */
  .tours {
    position: relative;
  }

  .tours__header {
    background: var(--warm-black);
    color: var(--cream);
    padding: 6rem 2.5rem 4rem;
    text-align: center;
  }

  .tours__label {
    font-family: var(--ff-body);
    font-size: 0.6rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--sepia);
    margin-bottom: 1rem;
  }

  .tours__heading {
    font-family: var(--ff-display);
    font-weight: 900;
    font-size: clamp(3.5rem, 10vw, 9rem);
    line-height: 0.9;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  .tours__subhead {
    font-family: var(--ff-body);
    font-style: italic;
    font-size: 1rem;
    color: rgba(245, 240, 227, 0.55);
    max-width: 40ch;
    margin: 0 auto;
  }

  /* Category blocks */
  .tours__category {
    padding: 4rem 0 5rem;
  }

  .tours__category--light {
    background: var(--cream);
    color: var(--warm-black);
  }

  .tours__category--dark {
    background: var(--warm-black);
    color: var(--cream);
  }

  .tours__category-header {
    padding: 0 2.5rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .tours__category-emoji {
    font-size: 1.5rem;
  }

  .tours__category-name {
    font-family: var(--ff-display);
    font-weight: 700;
    font-size: clamp(1.8rem, 4vw, 3rem);
    letter-spacing: -0.01em;
  }

  .tours__category-count {
    font-family: var(--ff-body);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.45;
  }

  /* Editorial grid layout */
  .tours__carousel {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3px;
    padding: 0 2.5rem 1.5rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  /* Tour card — Film Stills */
  .tour-card {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    cursor: pointer;
  }

  .tour-card--featured {
    grid-column: 1 / -1;
    aspect-ratio: 21 / 9;
  }

  .tour-card__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
