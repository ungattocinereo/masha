  <!-- ============ SCRIPTS ============ -->
  <script is:inline define:vars={{ whatsappNumber: contacts.whatsappNumber, toursData: ruTours.concat(enTours) }}>
    // ====== WhatsApp URL builder ======
    function toWhatsApp({ name, tour, note, prefix }) {
      const lines = [
        prefix || 'Здравствуйте, Маша!',
        name && `Меня зовут ${name}.`,
        tour && `Интересует экскурсия: ${tour}.`,
        note && `Пожелания: ${note}`,
      ].filter(Boolean);
      return `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(lines.join('\n'))}`;
    }

    // ====== Mobile nav ======
    const navToggle = document.getElementById('navToggle');
    const navLinks = document.getElementById('navLinks');
    navToggle?.addEventListener('click', () => {
      navLinks?.classList.toggle('nav__links--open');
      navToggle.classList.toggle('nav__toggle--open');
    });
    navLinks?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      navLinks.classList.remove('nav__links--open');
      navToggle?.classList.remove('nav__toggle--open');
    }));

    // ====== Sticky nav ======
    const nav = document.getElementById('nav');
    const hero = document.getElementById('top');
    if (hero && nav) {
      new IntersectionObserver(([entry]) => {
        nav.classList.toggle('nav--scrolled', !entry.isIntersecting);
      }, { threshold: 0.05 }).observe(hero);
    }

    // ====== Category chips ======
    const chips = document.querySelectorAll('.chip');
    const cards = document.querySelectorAll('.card');
    chips.forEach(chip => chip.addEventListener('click', () => {
      chips.forEach(c => c.classList.remove('chip--active'));
      chip.classList.add('chip--active');
      const cat = chip.dataset.category;
      cards.forEach(card => {
        const show = cat === 'all' || card.dataset.category === cat;
        card.style.display = show ? '' : 'none';
      });
    }));

    // ====== Quick book (WhatsApp directly from card) ======
    document.querySelectorAll('[data-quick-book]').forEach(btn => {
      btn.addEventListener('click', () => {
        const url = toWhatsApp({ tour: btn.dataset.tourTitle });
        window.open(url, '_blank', 'noopener');
      });
    });

    // ====== Modal ======
    const modal = document.getElementById('tourModal');
    const mKicker = document.getElementById('modalKicker');
    const mTitle = document.getElementById('modalTitle');
    const mSubtitle = document.getElementById('modalSubtitle');
    const mMeta = document.getElementById('modalMeta');
    const mLong = document.getElementById('modalLong');
    const mExtras = document.getElementById('modalExtras');
    const mPrice = document.getElementById('modalPrice');
    const mBook = document.getElementById('modalBook');

    function mdToHtml(s) {
      if (!s) return '';
      return s
        .split(/\n{2,}/)
        .map(block => {
          if (/^[•*\-]\s/m.test(block)) {
            const items = block.split(/\n/).filter(Boolean).map(line => {
              const cleaned = line.replace(/^[•*\-]\s*/, '').trim();
              return cleaned ? `<li>${inline(cleaned)}</li>` : '';
            }).join('');
            return `<ul>${items}</ul>`;
          }
          return `<p>${inline(block).replace(/\n/g, '<br>')}</p>`;
        })
        .join('');
      function inline(t) {
        return t
          .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
          .replace(/\*(.+?)\*/g, '$1');
      }
    }

    let closingFromHistory = false;

    function openModal(tourId) {
      const tour = toursData.find(t => t.id === tourId);
      if (!tour) return;
      mKicker.textContent = '';
      mTitle.textContent = tour.title;
      mSubtitle.textContent = tour.subtitle || '';
      mMeta.innerHTML = [
        tour.duration && `<span>⏱ ${tour.duration}</span>`,
        tour.maxPeople && `<span>👥 ${tour.maxPeople}</span>`,
      ].filter(Boolean).join('');
      mLong.innerHTML = mdToHtml(tour.longDescription || tour.description);
      mExtras.textContent = tour.extras || '';
      mExtras.style.display = tour.extras ? '' : 'none';
      mPrice.textContent = tour.price;
      mBook.onclick = () => window.open(toWhatsApp({ tour: tour.title }), '_blank', 'noopener');
      modal.showModal();
      // Push history entry so browser back closes modal
      history.pushState({ modal: tour.id }, '', `#tour-${tour.id}`);
    }

    document.querySelectorAll('[data-modal-open]').forEach(btn => {
      btn.addEventListener('click', () => openModal(btn.dataset.tourId));
    });

    document.querySelectorAll('[data-modal-close]').forEach(btn => {
      btn.addEventListener('click', () => modal.close());
    });

    modal?.addEventListener('click', (e) => {
      if (e.target === modal) {
        // backdrop click (dialog itself, not children)
        modal.close();
      }
    });

    // When modal closes (Esc / backdrop / X), rewind history unless close came from popstate
    modal?.addEventListener('close', () => {
      if (!closingFromHistory && history.state && history.state.modal) {
        history.back();
      }
      closingFromHistory = false;
    });

    // Browser back button — close the modal if open
    window.addEventListener('popstate', () => {
      if (modal?.open) {
        closingFromHistory = true;
        modal.close();
      }
    });

    // Deep-link: open modal if URL already has #tour-<id> on load
    window.addEventListener('DOMContentLoaded', () => {
      const m = location.hash.match(/^#tour-([\w-]+)$/);
      if (m) openModal(m[1]);
    });

    // ====== Form ======
    document.getElementById('booking-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const fd = new FormData(e.currentTarget);
      const url = toWhatsApp({
        name: fd.get('name'),
        tour: fd.get('tour'),
        note: fd.get('note'),
      });
      window.open(url, '_blank', 'noopener');
    });

