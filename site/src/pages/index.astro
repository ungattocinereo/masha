---
import { tours, categories, about, contacts } from '../data/tours';

const ruTours = tours.filter(t => t.lang !== 'en');
const enTours = tours.filter(t => t.lang === 'en');

const visibleCategories = categories.filter(cat =>
  ruTours.some(t => t.category === cat.id)
);

const licenseUrl = about.licenseUrl;
const qrSrc = '/images/ministry-qr.svg';

// ============ Inline Lucide SVG icons ============
// Icons use stroke="currentColor" by default; CSS applies gradient via stroke url.
const ICON_ATTRS = 'xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"';

const ICONS: Record<string, string> = {
  'mountain':       `<svg ${ICON_ATTRS}><path d="m8 3 4 8 5-5 5 15H2L8 3z"/></svg>`,
  'castle':         `<svg ${ICON_ATTRS}><path d="M22 20v-9H2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2Z"/><path d="M18 11V4H6v7"/><path d="M15 22v-4a3 3 0 0 0-3-3a3 3 0 0 0-3 3v4"/><path d="M22 11V9"/><path d="M2 11V9"/><path d="M6 4V2"/><path d="M18 4V2"/><path d="M10 4V2"/><path d="M14 4V2"/></svg>`,
  'waves':          `<svg ${ICON_ATTRS}><path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg>`,
  'puzzle':         `<svg ${ICON_ATTRS}><path d="M19.439 7.85c-.049.322.059.648.289.878l1.568 1.568c.47.47.706 1.087.706 1.704s-.235 1.233-.706 1.704l-1.611 1.611a.98.98 0 0 1-.837.276c-.47-.07-.802-.48-.968-.925a2.501 2.501 0 1 0-3.214 3.214c.446.166.855.497.925.968a.979.979 0 0 1-.276.837l-1.61 1.61a2.404 2.404 0 0 1-1.705.707 2.402 2.402 0 0 1-1.704-.706l-1.568-1.568a1.026 1.026 0 0 0-.877-.29c-.493.074-.84.504-1.02.968a2.5 2.5 0 1 1-3.237-3.237c.464-.18.894-.527.967-1.02a1.026 1.026 0 0 0-.289-.877l-1.568-1.568A2.402 2.402 0 0 1 1.998 12c0-.617.236-1.234.706-1.704L4.23 8.77c.24-.24.581-.353.917-.303.515.077.877.528 1.073 1.01a2.5 2.5 0 1 0 3.259-3.259c-.482-.196-.933-.558-1.01-1.073-.05-.336.062-.676.303-.917l1.609-1.61a2.402 2.402 0 0 1 1.704-.707c.617 0 1.234.236 1.704.706l1.568 1.568c.23.23.556.338.877.29.493-.074.84-.504 1.02-.968a2.5 2.5 0 1 1 3.237 3.237c-.464.18-.894.527-.967 1.02Z"/></svg>`,
  'sailboat':       `<svg ${ICON_ATTRS}><path d="M22 18H2a4 4 0 0 0 4 4h12a4 4 0 0 0 4-4Z"/><path d="M21 14 10 2 3 14h18Z"/><path d="M10 2v16"/></svg>`,
  'compass':        `<svg ${ICON_ATTRS}><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>`,
  'play-circle':    `<svg ${ICON_ATTRS}><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>`,
  'sparkles':       `<svg ${ICON_ATTRS}><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/></svg>`,
  'graduation-cap': `<svg ${ICON_ATTRS}><path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/><path d="M22 10v6"/><path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5"/></svg>`,
  'map-pin':        `<svg ${ICON_ATTRS}><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>`,
  'scroll-text':    `<svg ${ICON_ATTRS}><path d="M15 12h-5"/><path d="M15 8h-5"/><path d="M19 17V5a2 2 0 0 0-2-2H4"/><path d="M8 21h12a2 2 0 0 0 2-2v-1a1 1 0 0 0-1-1H11a1 1 0 0 0-1 1v1a2 2 0 1 1-4 0V5a2 2 0 1 0-4 0v2a1 1 0 0 0 1 1h3"/></svg>`,
  'clock':          `<svg ${ICON_ATTRS}><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  'users':          `<svg ${ICON_ATTRS}><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  'message-circle': `<svg ${ICON_ATTRS}><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22z"/></svg>`,
  'send':           `<svg ${ICON_ATTRS}><path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"/><path d="m21.854 2.147-10.94 10.939"/></svg>`,
  'instagram':      `<svg ${ICON_ATTRS}><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>`,
  'facebook':       `<svg ${ICON_ATTRS}><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`,
  'mail':           `<svg ${ICON_ATTRS}><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  'wallet':         `<svg ${ICON_ATTRS}><path d="M19 7V4a1 1 0 0 0-1-1H5a2 2 0 0 0 0 4h15a1 1 0 0 1 1 1v4h-3a2 2 0 0 0 0 4h3a1 1 0 0 0 1-1v-2a1 1 0 0 0-1-1"/><path d="M3 5v14a2 2 0 0 0 2 2h15a1 1 0 0 0 1-1v-4"/></svg>`,
  'route':          `<svg ${ICON_ATTRS}><circle cx="6" cy="19" r="3"/><path d="M9 19h8.5a3.5 3.5 0 0 0 0-7h-11a3.5 3.5 0 0 1 0-7H15"/><circle cx="18" cy="5" r="3"/></svg>`,
  'book-open':      `<svg ${ICON_ATTRS}><path d="M12 7v14"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/></svg>`,
  'heart-handshake':`<svg ${ICON_ATTRS}><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/><path d="M12 5 9.04 7.96a2.17 2.17 0 0 0 0 3.08v0c.82.82 2.13.85 3 .07l2.07-1.9a2.82 2.82 0 0 1 3.79 0l2.96 2.66"/><path d="m18 15-2-2"/><path d="m15 18-2-2"/></svg>`,
  'quote':          `<svg ${ICON_ATTRS}><path d="M16 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h3c0 2.5-2 4.5-4.5 4.5"/><path d="M5 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h3c0 2.5-2 4.5-4.5 4.5"/></svg>`,
  'layers':         `<svg ${ICON_ATTRS}><path d="M12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/></svg>`,
};

const iconSvg = (name: string): string => ICONS[name] || ICONS['sparkles'];

const CATEGORY_GRADIENTS: Record<string, string> = {
  naples:  'grad-terra-lemon',
  pompeii: 'grad-azure-terra',
  amalfi:  'grad-lemon-olive',
  quests:  'grad-terra-lemon',
  sea:     'grad-azure-sky',
  multi:   'grad-azure-terra',
  couch:   'grad-azure-sky',
  extra:   'grad-lemon-olive',
};
const gradForCategory = (cat: string): string => CATEGORY_GRADIENTS[cat] || 'grad-azure-terra';
---

<html lang="ru" data-lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Маша Шишкова — лицензированный гид по Кампании</title>
  <meta name="description" content="Авторские экскурсии по Неаполю, Помпеям, Амальфитанскому побережью, Капри и Пестуму. Лицензия Regione Campania." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@500;600;700&family=Cormorant+Infant:wght@400;500;600;700&family=Golos+Text:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>

<body>

  <!-- GRADIENT DEFS FOR LUCIDE ICONS -->
  <svg width="0" height="0" style="position:absolute;overflow:hidden" aria-hidden="true">
    <defs>
      <linearGradient id="grad-azure-terra" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#1a6b8a"/>
        <stop offset="100%" stop-color="#c4622d"/>
      </linearGradient>
      <linearGradient id="grad-lemon-olive" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#d9a441"/>
        <stop offset="100%" stop-color="#6b7c3e"/>
      </linearGradient>
      <linearGradient id="grad-terra-lemon" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#c4622d"/>
        <stop offset="100%" stop-color="#d9a441"/>
      </linearGradient>
      <linearGradient id="grad-azure-sky" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#0d4a5e"/>
        <stop offset="100%" stop-color="#2b8fad"/>
      </linearGradient>
    </defs>
  </svg>

  <!-- ============ NAV ============ -->
  <nav class="nav" id="nav">
    <div class="nav__inner">
      <a href="#top" class="nav__logo">
        <span class="nav__logo-name" data-i18n="logo.name">Маша Шишкова</span>
        <span class="nav__logo-sub" data-i18n="logo.sub">гид в Кампании</span>
      </a>

      <ul class="nav__links" id="navLinks">
        <li><a href="#about"   data-i18n="nav.about">Обо мне</a></li>
        <li><a href="#tours"   data-i18n="nav.tours">Экскурсии</a></li>
        <li><a href="#couch"   data-i18n="nav.couch">На диване</a></li>
        <li><a href="#contact" data-i18n="nav.contact">Контакты</a></li>
        <li><a href="#form" class="nav__cta" data-i18n="nav.book">Записаться</a></li>
      </ul>

      <div class="lang-switch" id="langToggle" role="group" aria-label="Language">
        <span class="lang-switch__thumb" aria-hidden="true"></span>
        <button type="button" class="lang-switch__opt" data-lang="ru" aria-label="Русский">RU</button>
        <button type="button" class="lang-switch__opt" data-lang="en" aria-label="English">EN</button>
      </div>

      <button class="nav__toggle" aria-label="Menu" id="navToggle">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- ============ HERO ============ -->
  <section class="hero" id="top">
    <div class="hero__bg" role="img" aria-label="Amalfi coast"></div>
    <div class="hero__overlay"></div>

    <div class="hero__content">
      <p class="hero__over">
        <span data-i18n="hero.over1">ЛИЦЕНЗИРОВАННЫЙ ГИД</span>
        <span data-i18n="hero.over2">в регионе Кампания</span>
      </p>

      <h1 class="hero__title" data-i18n="hero.name">{about.name}</h1>

      <p class="hero__geo">
        {about.geo.map((place, i) => (
          <>
            {i > 0 && <span class="hero__geo-sep">·</span>}
            <span data-i18n={`geo.${i}`}>{place}</span>
          </>
        ))}
      </p>

      <p class="hero__tagline" data-i18n="hero.tagline">{about.tagline}</p>

      <div class="hero__actions">
        <a href="#tours" class="btn btn--primary" data-i18n="hero.cta.primary">Выбрать экскурсию</a>
        <a href={`https://wa.me/${contacts.whatsappNumber}?text=${encodeURIComponent('Здравствуйте, Маша!')}`}
           target="_blank" rel="noopener"
           class="btn btn--outline" data-i18n="hero.cta.secondary">Написать в WhatsApp</a>
      </div>

      <a class="hero__license" href={licenseUrl} target="_blank" rel="noopener">
        <img class="hero__license-qr" src={qrSrc} alt="QR" width="56" height="56" data-i18n-alt="hero.license.qrAlt" />
        <span class="hero__license-text">
          <span class="hero__license-label" data-i18n="hero.license.label">Лицензия Regione Campania</span>
          <span class="hero__license-url">portaleprofessioni.ministeroturismo.gov.it</span>
        </span>
      </a>
    </div>

    <a href="#about" class="hero__scroll" aria-label="Scroll" data-i18n-aria="hero.scroll.aria">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
    </a>
  </section>

  <div class="divider" aria-hidden="true"></div>

  <!-- ============ ABOUT ============ -->
  <section class="about" id="about">
    <div class="container">
      <div class="about__head">
        <p class="kicker" data-i18n="about.kicker">Обо мне</p>
        <h2 class="section-title" data-i18n="about.name">{about.name}</h2>
      </div>

      <div class="about__grid">
        <!-- POLAROID PHOTO -->
        <div class="about__photo-area">
          <div class="polaroid">
            <span class="polaroid__tape polaroid__tape--left" aria-hidden="true"></span>
            <span class="polaroid__tape polaroid__tape--right" aria-hidden="true"></span>
            <div class="polaroid__photo">
              <img class="polaroid__img" src="/images/masha.jpg" alt={about.name} />
              <video class="polaroid__video"
                     autoplay muted loop playsinline
                     preload="metadata"
                     poster="/images/masha.jpg">
                <source src="/video/masha-vert.mp4" type="video/mp4" />
              </video>
            </div>
            <div class="polaroid__caption">
              <span class="polaroid__name" data-i18n="polaroid.name">Маша Шишкова</span>
              <span class="polaroid__role" data-i18n="polaroid.role">Лицензированный гид · Санкт-Петербург · Амальфи</span>
            </div>
          </div>
        </div>

        <!-- QUOTE (tagline) -->
        <div class="about__quote">
          <span class="about__quote-mark" aria-hidden="true">
            <span class="icon icon--md" set:html={iconSvg('quote')} />
          </span>
          <p class="about__tagline" data-i18n="about.tagline">{about.tagline}</p>
          <span class="about__quote-rule" aria-hidden="true"></span>
        </div>
      </div>

      <!-- PILLARS -->
      <div class="pillars">
        <article class="pillar">
          <span class="pillar__num">01</span>
          <span class="pillar__icon">
            <span class="icon icon--lg" style="--grad: url(#grad-terra-lemon)" set:html={iconSvg('heart-handshake')} />
          </span>
          <p class="pillar__label" data-i18n="about.pillar1.label">Подход</p>
          <p class="pillar__text"  data-i18n="about.pillar1.text">{about.bio[0]}</p>
        </article>
        <article class="pillar">
          <span class="pillar__num">02</span>
          <span class="pillar__icon">
            <span class="icon icon--lg" style="--grad: url(#grad-azure-terra)" set:html={iconSvg('book-open')} />
          </span>
          <p class="pillar__label" data-i18n="about.pillar2.label">Формат</p>
          <p class="pillar__text"  data-i18n="about.pillar2.text">{about.bio[1]}</p>
        </article>
        <article class="pillar">
          <span class="pillar__num">03</span>
          <span class="pillar__icon">
            <span class="icon icon--lg" style="--grad: url(#grad-lemon-olive)" set:html={iconSvg('puzzle')} />
          </span>
          <p class="pillar__label" data-i18n="about.pillar3.label">Для любопытных</p>
          <p class="pillar__text"  data-i18n="about.pillar3.text">{about.bio[2]}</p>
        </article>
      </div>

      <!-- CREDENTIALS STRIP -->
      <div class="about__credentials">
        {about.credentials.map((c, i) => (
          <div class="about__credential">
            <span class="icon icon--sm" set:html={iconSvg(c.icon)} />
            <span data-i18n={`credential.${i}`}>{c.text}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="divider" aria-hidden="true"></div>

  <!-- ============ TOURS ============ -->
  <section class="tours" id="tours">
    <div class="container">
      <p class="kicker kicker--center" data-i18n="tours.kicker">Маршруты</p>
      <h2 class="section-title section-title--center" data-i18n="tours.title">Экскурсии и туры</h2>
      <p class="tours__intro" data-i18n="tours.intro">Каждый маршрут — авторский. От двухчасовой прогулки до многодневного путешествия по Кампании.</p>

      <!-- Category chips -->
      <div class="chips-wrap">
        <div class="chips" role="tablist">
          <button class="chip chip--active" data-category="all" role="tab">
            <span class="chip__icon" set:html={iconSvg('layers')} />
            <span class="chip__text" data-i18n="chip.all">Все</span>
          </button>
          {visibleCategories.map((cat) => (
            <button class="chip" data-category={cat.id} role="tab" style={`--grad: url(#${gradForCategory(cat.id)})`}>
              <span class="chip__icon" set:html={iconSvg(cat.icon)} />
              <span class="chip__text" data-i18n={`category.${cat.id}`}>{cat.name}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Tours grid -->
      <div class="tours__grid" data-lang-only="ru">
        {ruTours.map((tour, idx) => {
          const cat = categories.find(c => c.id === tour.category);
          const gradId = gradForCategory(tour.category);
          return (
            <article class="card" data-category={tour.category} style={`--delay: ${(idx % 9) * 0.05}s`}>
              <div class="card__media">
                <img src={tour.image} alt={tour.title} loading="lazy" />
                <span class="card__cat">
                  <span class="icon icon--sm" style={`--grad: url(#${gradId})`} set:html={iconSvg(cat?.icon || 'sparkles')} />
                  <span data-i18n={`category.${cat?.id}`}>{cat?.name}</span>
                </span>
              </div>
              <div class="card__body">
                <h3 class="card__title">{tour.title}</h3>
                <p class="card__subtitle">{tour.subtitle}</p>
                <p class="card__desc">{tour.description}</p>
                <div class="card__meta">
                  <span class="card__meta-item">
                    <span class="icon icon--xs" set:html={iconSvg('clock')} />
                    {tour.duration}
                  </span>
                  {tour.maxPeople && (
                    <span class="card__meta-item">
                      <span class="icon icon--xs" set:html={iconSvg('users')} />
                      {tour.maxPeople}
                    </span>
                  )}
                </div>
                {tour.extras && <p class="card__extras">{tour.extras}</p>}
                <div class="card__footer">
                  <span class="card__price">{tour.price}</span>
                  <div class="card__actions">
                    {tour.externalUrl ? (
                      <a href={tour.externalUrl} target="_blank" rel="noopener" class="btn btn--small btn--primary" data-i18n="card.telegram">
                        Открыть в Telegram
                      </a>
                    ) : (
                      <>
                        <button
                          type="button"
                          class="btn btn--small btn--ghost"
                          data-modal-open
                          data-tour-id={tour.id}
                          data-i18n="card.details"
                        >Подробнее</button>
                        <button
                          type="button"
                          class="btn btn--small btn--primary"
                          data-quick-book
                          data-tour-title={tour.title}
                          data-i18n="card.book"
                        >В WhatsApp</button>
                      </>
                    )}
                  </div>
                </div>
              </div>
            </article>
          );
        })}
      </div>

      <!-- English tours grid -->
      <div class="tours__grid" data-lang-only="en">
        {enTours.map((tour) => {
          const cat = categories.find(c => c.id === tour.category);
          return (
            <article class="card" data-category={tour.category}>
              <div class="card__media">
                <img src={tour.image} alt={tour.title} loading="lazy" />
                <span class="card__cat">
                  <span class="icon icon--sm" set:html={iconSvg(cat?.icon || 'sparkles')} />
                  {cat?.name}
                </span>
              </div>
              <div class="card__body">
                <h3 class="card__title">{tour.title}</h3>
                <p class="card__subtitle">{tour.subtitle}</p>
                <p class="card__desc">{tour.description}</p>
                <div class="card__meta">
                  <span class="card__meta-item">
                    <span class="icon icon--xs" set:html={iconSvg('clock')} />
                    {tour.duration}
                  </span>
                  {tour.maxPeople && (
                    <span class="card__meta-item">
                      <span class="icon icon--xs" set:html={iconSvg('users')} />
                      {tour.maxPeople}
                    </span>
                  )}
                </div>
                {tour.extras && <p class="card__extras">{tour.extras}</p>}
                <div class="card__footer">
                  <span class="card__price">{tour.price}</span>
                  <div class="card__actions">
                    <button type="button" class="btn btn--small btn--ghost" data-modal-open data-tour-id={tour.id}>Read more</button>
                    <button type="button" class="btn btn--small btn--primary" data-quick-book data-tour-title={tour.title}>WhatsApp</button>
                  </div>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </div>
