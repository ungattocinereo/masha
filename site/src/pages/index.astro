    function applyI18n(lang) {
      const dict = I18N[lang] || I18N.ru;
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        const val = dict[key];
        if (val == null) return;
        if (val.includes('<br>') || val.includes('<strong>')) el.innerHTML = val;
        else el.textContent = val;
      });
      document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
        const v = dict[el.getAttribute('data-i18n-placeholder')];
        if (v != null) el.setAttribute('placeholder', v);
      });
      document.querySelectorAll('[data-i18n-aria]').forEach(el => {
        const v = dict[el.getAttribute('data-i18n-aria')];
        if (v != null) el.setAttribute('aria-label', v);
      });
      document.querySelectorAll('[data-i18n-alt]').forEach(el => {
        const v = dict[el.getAttribute('data-i18n-alt')];
        if (v != null) el.setAttribute('alt', v);
      });
      document.querySelectorAll('[data-i18n-label]').forEach(el => {
        const v = dict[el.getAttribute('data-i18n-label')];
        if (v != null) el.setAttribute('label', v);
      });
      document.documentElement.setAttribute('lang', lang);
    }

    // ====== Lang switch ======
    const langToggle = document.getElementById('langToggle');
    const saved = localStorage.getItem('lang');
    const initialLang = saved === 'en' ? 'en' : 'ru';
    document.documentElement.dataset.lang = initialLang;
    applyI18n(initialLang);

    function setLang(lang) {
      if (document.documentElement.dataset.lang === lang) return;
      document.body.classList.add('is-switching');
      setTimeout(() => {
        document.documentElement.dataset.lang = lang;
        localStorage.setItem('lang', lang);
        applyI18n(lang);
        requestAnimationFrame(() => {
          document.body.classList.remove('is-switching');
        });
      }, 180);
    }

    langToggle?.addEventListener('click', (e) => {
      const opt = e.target.closest('[data-lang]');
      const nextLang = opt?.dataset.lang
        || (document.documentElement.dataset.lang === 'en' ? 'ru' : 'en');
      setLang(nextLang);
    });

    // ====== Force polaroid video to play when visible ======
    document.querySelectorAll('.polaroid__video').forEach(v => {
      const tryPlay = () => { v.play().catch(() => {}); };
      tryPlay();
      new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) tryPlay(); });
      }, { threshold: 0.1 }).observe(v);
    });

    // ====== Scroll reveal ======
    const reveal = new IntersectionObserver((entries) => {
      entries.forEach(en => {
        if (en.isIntersecting) {
          en.target.classList.add('is-visible');
          reveal.unobserve(en.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.card, .about__quote, .about__photo-area, .pillar, .contact__card, .form-section__info, .form, .couch__inner').forEach(el => reveal.observe(el));
  </script>

  <!-- ============ STYLES ============ -->
  <style is:global>
    :root {
      --azure:       #1a6b8a;
      --azure-deep:  #0d4a5e;
      --azure-light: #2b8fad;
      --terracotta:  #c4622d;
      --terracotta-light: #d9794a;
      --lemon:       #d9a441;
      --olive:       #6b7c3e;
      --cream:       #fefcf7;
      --cream-warm:  #f5efe2;
      --paper:       #faf6ee;
      --ink:         #1e1812;
      --text:        #2c2418;
      --text-mute:   #6b5d4a;
      --text-soft:   #998670;
      --line:        #e8ddc8;

      --font-display: 'Cormorant Infant', Georgia, 'Times New Roman', serif;
      --font-body:    'Golos Text', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;

      --nav-h: 72px;
      --container: 1200px;
      --radius-sm: 6px;
      --radius-md: 12px;
      --radius-lg: 20px;
      --radius-xl: 28px;

      --shadow-sm: 0 1px 2px rgba(30, 24, 18, 0.04), 0 2px 8px rgba(30, 24, 18, 0.06);
      --shadow-md: 0 2px 6px rgba(30, 24, 18, 0.06), 0 12px 40px rgba(30, 24, 18, 0.08);
      --shadow-lg: 0 4px 12px rgba(30, 24, 18, 0.08), 0 24px 80px rgba(30, 24, 18, 0.12);

      --ease: cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
    body {
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.6;
      color: var(--text);
      background: var(--cream);
      overflow-x: hidden;
    }
    img, svg, video { max-width: 100%; display: block; }
    a { color: var(--azure); text-decoration: none; transition: color 0.2s; }
    button { font-family: inherit; cursor: pointer; border: none; background: none; color: inherit; }

    .container { max-width: var(--container); margin: 0 auto; padding: 0 clamp(1.25rem, 4vw, 2.5rem); }

    /* ============ LANG TOGGLE ============ */
    html[data-lang="ru"] [data-lang-only="en"] { display: none; }
    html[data-lang="en"] [data-lang-only="ru"] { display: none; }
    html[data-lang="ru"] [data-lang-label="ru"] { color: var(--text); font-weight: 600; }
    html[data-lang="ru"] [data-lang-label="en"] { color: var(--text-soft); }
    html[data-lang="en"] [data-lang-label="en"] { color: var(--text); font-weight: 600; }
    html[data-lang="en"] [data-lang-label="ru"] { color: var(--text-soft); }

    /* ============ TYPOGRAPHY ============ */
    .section-title {
      font-family: var(--font-display);
      font-size: clamp(2rem, 1.5rem + 2.5vw, 3.5rem);
      font-weight: 500;
      line-height: 1.05;
      letter-spacing: -0.01em;
      color: var(--ink);
      margin-bottom: 1rem;
    }
    .section-title--center { text-align: center; }

    .kicker {
      font-family: var(--font-body);
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--terracotta);
      margin-bottom: 0.8rem;
    }
    .kicker--center { text-align: center; }

    /* ============ DIVIDER ============ */
    .divider {
      width: 120px; height: 2px;
      margin: 0 auto;
      background: linear-gradient(90deg, var(--azure) 50%, var(--terracotta) 50%);
      opacity: 0.55;
    }

    /* ============ ICONS ============ */
    .icon { display: inline-flex; align-items: center; justify-content: center; vertical-align: middle; color: var(--azure); }
    .icon svg { width: 100%; height: 100%; }
    .icon--xs { width: 14px; height: 14px; }
    .icon--sm { width: 18px; height: 18px; }
    .icon--md { width: 24px; height: 24px; }
    .icon--lg { width: 36px; height: 36px; }
    .icon--xl { width: 64px; height: 64px; }

    /* gradient strokes for icons (not `.icon--plain`) */
    .icon:not(.icon--plain) svg { stroke: var(--grad, url(#grad-azure-terra)); }
    .icon:not(.icon--plain) svg * { stroke: var(--grad, url(#grad-azure-terra)); }

    /* ============ BUTTONS ============ */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5em;
      font-family: var(--font-body);
      font-size: 0.95rem;
      font-weight: 500;
      letter-spacing: 0.02em;
      padding: 0.8em 1.8em;
      border-radius: 999px;
      border: 1.5px solid transparent;
      transition: all 0.25s var(--ease);
      white-space: nowrap;
    }
    .btn--primary { background: var(--ink); color: var(--cream); border-color: var(--ink); }
    .btn--primary:hover { background: var(--terracotta); border-color: var(--terracotta); transform: translateY(-1px); box-shadow: var(--shadow-md); }
    .btn--outline { background: transparent; color: #fff; border-color: rgba(255,255,255,0.7); }
    .btn--outline:hover { background: rgba(255,255,255,0.12); border-color: #fff; }
    .btn--ghost { background: transparent; color: var(--text); border-color: var(--line); }
    .btn--ghost:hover { background: var(--paper); border-color: var(--text); }
    .btn--small { font-size: 0.85rem; padding: 0.55em 1.2em; }
    .btn--lg { font-size: 1rem; padding: 1em 2.2em; }
    .btn--full { width: 100%; }

    /* ============ NAVIGATION ============ */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      transition: background 0.4s var(--ease), box-shadow 0.4s var(--ease), padding 0.3s var(--ease);
      padding: 1rem 0;
    }
    .nav--scrolled {
      background: rgba(254, 252, 247, 0.92);
      backdrop-filter: blur(18px) saturate(1.2);
      -webkit-backdrop-filter: blur(18px) saturate(1.2);
      box-shadow: 0 1px 0 rgba(30, 24, 18, 0.06);
      padding: 0.5rem 0;
    }
    .nav__inner {
      max-width: var(--container);
      margin: 0 auto;
      padding: 0 clamp(1.25rem, 4vw, 2.5rem);
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }
    .nav__logo {
      display: flex; flex-direction: column; line-height: 1;
      color: #fff;
      text-decoration: none;
      margin-right: auto;
      transition: color 0.3s;
    }
    .nav__logo-name {
      font-family: var(--font-display);
      font-size: 1.35rem;
      font-weight: 600;
      letter-spacing: -0.01em;
    }
    .nav__logo-sub {
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-top: 0.2rem;
      opacity: 0.7;
    }
    .nav--scrolled .nav__logo { color: var(--ink); }

    .nav__links {
      display: flex; gap: 0.25rem; align-items: center; list-style: none;
    }
    .nav__links a {
      display: inline-block;
      color: rgba(255,255,255,0.9);
      font-size: 0.92rem;
      font-weight: 500;
      padding: 0.55em 1.1em;
      border-radius: 999px;
      transition: all 0.25s var(--ease);
    }
    .nav__links a:hover { color: #fff; background: rgba(255,255,255,0.12); }
    .nav--scrolled .nav__links a { color: var(--text); }
    .nav--scrolled .nav__links a:hover { background: var(--cream-warm); }
    .nav__cta {
      border: 1.5px solid rgba(255,255,255,0.45);
      background: rgba(255,255,255,0.08);
    }
    .nav--scrolled .nav__cta {
      background: var(--ink) !important;
      color: var(--cream) !important;
      border-color: var(--ink);
    }
    .nav__cta:hover { background: rgba(255,255,255,0.2) !important; }
    .nav--scrolled .nav__cta:hover { background: var(--terracotta) !important; border-color: var(--terracotta); }

    /* ============ LANG SWITCH ============ */
    .lang-switch {
      position: relative;
      display: inline-flex;
      align-items: center;
      padding: 3px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.14);
      border: 1px solid rgba(255, 255, 255, 0.28);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      box-shadow: 0 4px 14px -4px rgba(0, 0, 0, 0.2);
      user-select: none;
      isolation: isolate;
    }
    .lang-switch__thumb {
      position: absolute;
      top: 3px; left: 3px;
      width: calc(50% - 3px);
      bottom: 3px;
      background: #fff;
      border-radius: 999px;
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.12);
      transition: transform 0.35s var(--ease);
      z-index: 0;
    }
    html[data-lang="en"] .lang-switch__thumb { transform: translateX(100%); }
    .lang-switch__opt {
      position: relative;
      z-index: 1;
      padding: 0.5em 0.95em;
      font-family: var(--font-body);
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      color: rgba(255, 255, 255, 0.82);
      min-width: 40px;
      text-align: center;
      background: transparent;
      cursor: pointer;
      transition: color 0.3s var(--ease);
    }
    html[data-lang="ru"] .lang-switch__opt[data-lang="ru"],
    html[data-lang="en"] .lang-switch__opt[data-lang="en"] {
      color: var(--ink);
    }
    .nav--scrolled .lang-switch {
      background: var(--paper);
      border-color: var(--line);
      box-shadow: 0 1px 3px rgba(30, 24, 18, 0.06);
    }
    .nav--scrolled .lang-switch__thumb { background: var(--ink); }
    .nav--scrolled .lang-switch__opt { color: var(--text-mute); }
    .nav--scrolled html[data-lang="ru"] .lang-switch__opt[data-lang="ru"],
    .nav--scrolled html[data-lang="en"] .lang-switch__opt[data-lang="en"],
    html[data-lang="ru"] .nav--scrolled .lang-switch__opt[data-lang="ru"],
    html[data-lang="en"] .nav--scrolled .lang-switch__opt[data-lang="en"] {
      color: var(--cream);
    }

    /* ============ SWITCHING INDICATOR ============ */
    body.is-switching .hero__content,
    body.is-switching .about,
    body.is-switching .tours,
    body.is-switching .couch,
    body.is-switching .form-section,
    body.is-switching .contact,
    body.is-switching .footer {
      opacity: 0;
      transition: opacity 0.18s ease;
    }
    body.is-switching { pointer-events: none; }
    body.is-switching::after {
      content: '';
      position: fixed;
      top: 0; left: 0;
      height: 3px;
      width: 100%;
      background: linear-gradient(90deg,
        transparent 0%,
        var(--terracotta) 30%,
        var(--azure) 70%,
        transparent 100%);
      background-size: 200% 100%;
      z-index: 9999;
      animation: langProgress 0.6s ease;
    }
    @keyframes langProgress {
      0%   { background-position: 100% 0; }
      100% { background-position: -100% 0; }
    }

    .nav__toggle { display: none; flex-direction: column; gap: 5px; padding: 6px; }
    .nav__toggle span { display: block; width: 24px; height: 2px; background: #fff; border-radius: 2px; transition: all 0.3s; }
    .nav--scrolled .nav__toggle span { background: var(--ink); }
    .nav__toggle--open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav__toggle--open span:nth-child(2) { opacity: 0; }
    .nav__toggle--open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    @media (max-width: 900px) {
