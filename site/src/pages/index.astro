    /* ============ ABOUT ============ */
    .about { padding: clamp(4rem, 8vw, 7rem) 0; }
    .about__head { text-align: center; margin-bottom: clamp(2.5rem, 5vw, 4rem); }

    .about__grid {
      display: grid;
      grid-template-columns: minmax(260px, 1fr) 1.3fr;
      gap: clamp(2rem, 5vw, 5rem);
      align-items: center;
      margin-bottom: clamp(3rem, 6vw, 5rem);
    }

    /* POLAROID */
    .about__photo-area {
      display: flex;
      justify-content: center;
      opacity: 0;
      transform: translateY(20px);
      transition: all 0.8s var(--ease);
    }
    .about__photo-area.is-visible { opacity: 1; transform: translateY(0); }

    .polaroid {
      position: relative;
      padding: 14px 14px 18px;
      background: #fdfaf2;
      background-image:
        linear-gradient(180deg, rgba(200, 180, 140, 0.05) 0%, rgba(200, 180, 140, 0) 30%),
        radial-gradient(circle at 20% 85%, rgba(200, 180, 140, 0.06), transparent 40%);
      box-shadow:
        0 2px 3px rgba(30, 24, 18, 0.08),
        0 14px 28px -10px rgba(30, 24, 18, 0.25),
        0 30px 60px -30px rgba(30, 24, 18, 0.35);
      transform: rotate(-2.2deg);
      transition: transform 0.6s var(--ease);
      max-width: 340px;
      width: 100%;
    }
    .polaroid:hover { transform: rotate(0deg) scale(1.01); }

    .polaroid__photo {
      aspect-ratio: 4/5;
      overflow: hidden;
      background: #e8e2d2;
      /* subtle film grain */
      position: relative;
    }
    .polaroid__photo::after {
      content: '';
      position: absolute; inset: 0;
      background-image: radial-gradient(rgba(30, 24, 18, 0.06) 1px, transparent 1px);
      background-size: 3px 3px;
      mix-blend-mode: multiply;
      pointer-events: none;
      opacity: 0.5;
    }
    .polaroid__photo img,
    .polaroid__photo video {
      width: 100%; height: 100%;
      object-fit: cover;
      filter: saturate(0.92) contrast(1.02);
      display: block;
    }
    /* Mobile (default): show image, hide video */
    .polaroid__video { display: none; }
    .polaroid__img   { display: block; }
    /* Desktop: swap — show video, hide image */
    @media (min-width: 781px) {
      .polaroid__video { display: block; }
      .polaroid__img   { display: none; }
    }

    .polaroid__caption {
      margin-top: 16px;
      text-align: center;
      font-family: 'Caveat', 'Cormorant Infant', cursive;
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }
    .polaroid__name {
      font-family: 'Caveat', cursive;
      font-size: 1.6rem;
      font-weight: 600;
      color: #2c2418;
      letter-spacing: 0.01em;
      line-height: 1;
    }
    .polaroid__role {
      font-family: var(--font-body);
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #6b5d4a;
    }

    .polaroid__tape {
      position: absolute;
      width: 90px; height: 26px;
      background: rgba(244, 220, 130, 0.55);
      border: 1px solid rgba(180, 160, 90, 0.25);
      box-shadow: 0 1px 2px rgba(30, 24, 18, 0.12);
      pointer-events: none;
    }
    .polaroid__tape::before,
    .polaroid__tape::after {
      content: ''; position: absolute; top: 0; bottom: 0;
      width: 6px;
      background-image:
        linear-gradient(45deg, transparent 33%, rgba(255,255,255,0.4) 33%, rgba(255,255,255,0.4) 66%, transparent 66%);
      background-size: 4px 4px;
    }
    .polaroid__tape--left  { top: -12px; left: -14px;  transform: rotate(-18deg); }
    .polaroid__tape--right { top: -12px; right: -14px; transform: rotate(20deg); }

    /* QUOTE (tagline) */
    .about__quote {
      position: relative;
      padding: 2rem 0 2rem 2.5rem;
      opacity: 0;
      transform: translateY(20px);
      transition: all 0.8s var(--ease) 0.15s;
    }
    .about__quote.is-visible,
    .about__photo-area.is-visible + .about__quote { opacity: 1; transform: translateY(0); }

    .about__quote-mark {
      display: inline-flex;
      width: 40px; height: 40px;
      align-items: center; justify-content: center;
      margin-bottom: 1rem;
      border-radius: 50%;
      background: linear-gradient(135deg, rgba(196, 98, 45, 0.12), rgba(26, 107, 138, 0.1));
    }
    .about__quote-mark .icon svg { stroke: url(#grad-terra-lemon); width: 22px; height: 22px; }

    .about__tagline {
      font-family: var(--font-display);
      font-size: clamp(1.6rem, 1.2rem + 1.5vw, 2.4rem);
      font-weight: 500;
      line-height: 1.2;
      letter-spacing: -0.01em;
      color: var(--ink);
      margin: 0 0 1.25rem;
      max-width: 540px;
    }
    .about__quote-rule {
      display: block;
      width: 80px; height: 2px;
      background: linear-gradient(90deg, var(--terracotta), transparent);
    }

    /* PILLARS */
    .pillars {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: clamp(1rem, 2.5vw, 2rem);
      margin-bottom: clamp(3rem, 5vw, 4rem);
    }
    .pillar {
      position: relative;
      padding: 2rem 1.6rem 1.8rem;
      background: var(--cream);
      border: 1px solid var(--line);
      overflow: hidden;
      transition: all 0.35s var(--ease);
      opacity: 0;
      transform: translateY(20px);
    }
    .pillar:nth-child(1) { transition-delay: 0.1s; }
    .pillar:nth-child(2) { transition-delay: 0.2s; }
    .pillar:nth-child(3) { transition-delay: 0.3s; }
    .about.is-visible .pillar,
    .pillars.is-visible .pillar,
    body .pillar.is-visible { opacity: 1; transform: translateY(0); }
    .pillar:hover {
      border-color: var(--terracotta);
      transform: translateY(-4px);
      box-shadow: var(--shadow-md);
    }
    .pillar::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 3px;
      background: linear-gradient(90deg, var(--terracotta) 0%, var(--azure) 100%);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.5s var(--ease);
    }
    .pillar:hover::before { transform: scaleX(1); }

    .pillar__num {
      position: absolute;
      top: 1rem; right: 1.4rem;
      font-family: var(--font-display);
      font-size: 3.5rem;
      font-weight: 600;
      line-height: 1;
      color: var(--line);
      letter-spacing: -0.02em;
      user-select: none;
    }
    .pillar__icon {
      display: inline-flex;
      width: 64px; height: 64px;
      align-items: center; justify-content: center;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--paper), var(--cream-warm));
      border: 1px solid var(--line);
      margin-bottom: 1.2rem;
      position: relative;
      z-index: 1;
    }
    .pillar__icon .icon svg { width: 30px; height: 30px; }

    .pillar__label {
      font-family: var(--font-body);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--terracotta);
      margin-bottom: 0.7rem;
    }
    .pillar__text {
      font-family: var(--font-display);
      font-size: clamp(1.1rem, 0.95rem + 0.5vw, 1.25rem);
      font-weight: 500;
      line-height: 1.35;
      color: var(--ink);
      letter-spacing: -0.005em;
    }

    .about__credentials {
      display: flex; flex-wrap: wrap; gap: 0.7rem;
      justify-content: center;
      margin-top: 1.5rem;
    }
    .about__credential {
      display: inline-flex; align-items: center; gap: 0.55rem;
      padding: 0.55em 1em;
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 999px;
      font-size: 0.85rem;
      color: var(--text);
    }

    @media (max-width: 900px) {
      .pillars { grid-template-columns: 1fr; }
    }
    @media (max-width: 780px) {
      .about__grid { grid-template-columns: 1fr; }
      .about__quote { padding: 2rem 0 0; text-align: center; }
      .about__tagline { margin-left: auto; margin-right: auto; }
      .about__quote-rule { margin: 0 auto; }
    }

    /* ============ TOURS ============ */
    .tours { padding: clamp(4rem, 8vw, 7rem) 0; background: var(--paper); }
    .tours__intro {
      text-align: center;
      max-width: 560px;
      margin: 0 auto 2.5rem;
      color: var(--text-mute);
    }
    .chips-wrap {
      position: relative;
      margin: 0 calc(clamp(1.25rem, 4vw, 2.5rem) * -1) 3rem;
      padding: 0 clamp(1.25rem, 4vw, 2.5rem);
    }
    .chips {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.6rem;
    }
    .chip {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      font-family: var(--font-body);
      font-size: 0.9rem;
      font-weight: 500;
      line-height: 1;
      padding: 0.7em 1.2em 0.7em 0.85em;
      border-radius: 999px;
      border: 1.5px solid var(--line);
      background: var(--cream);
      color: var(--text-mute);
      transition: all 0.25s var(--ease);
      cursor: pointer;
      white-space: nowrap;
    }
    .chip__icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px; height: 28px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--paper), var(--cream-warm));
      border: 1px solid var(--line);
      transition: all 0.25s var(--ease);
      flex-shrink: 0;
    }
    .chip__icon svg {
      width: 16px; height: 16px;
      stroke: var(--grad, url(#grad-azure-terra));
      transition: stroke 0.2s;
    }
    .chip__text {
      display: inline-block;
      color: inherit;
    }

    .chip:not(.chip--active):hover {
      border-color: var(--ink);
      color: var(--ink);
      transform: translateY(-1px);
    }
    .chip:not(.chip--active):hover .chip__icon {
      background: var(--cream);
      border-color: var(--ink);
    }

    .chip--active,
    .chip--active:hover {
      background: var(--ink);
      color: var(--cream);
      border-color: var(--ink);
      box-shadow: 0 4px 16px -4px rgba(30, 24, 18, 0.3);
      transform: none;
    }
    .chip--active .chip__icon,
    .chip--active:hover .chip__icon {
      background: rgba(255, 255, 255, 0.14);
      border-color: rgba(255, 255, 255, 0.28);
    }
    .chip--active .chip__icon svg,
    .chip--active:hover .chip__icon svg {
      stroke: var(--cream) !important;
    }

    /* Horizontal scroll on mobile */
    @media (max-width: 720px) {
      .chips-wrap {
        overflow-x: auto;
        overflow-y: hidden;
        -webkit-overflow-scrolling: touch;
        scroll-snap-type: x proximity;
        scrollbar-width: none;
        mask-image: linear-gradient(90deg,
          transparent 0,
          #000 clamp(1.25rem, 4vw, 2.5rem),
          #000 calc(100% - clamp(1.25rem, 4vw, 2.5rem)),
          transparent 100%);
        -webkit-mask-image: linear-gradient(90deg,
          transparent 0,
          #000 clamp(1.25rem, 4vw, 2.5rem),
          #000 calc(100% - clamp(1.25rem, 4vw, 2.5rem)),
          transparent 100%);
      }
      .chips-wrap::-webkit-scrollbar { display: none; }
      .chips {
        flex-wrap: nowrap;
        justify-content: flex-start;
        gap: 0.5rem;
        padding-bottom: 4px;
      }
      .chip {
        scroll-snap-align: start;
        flex-shrink: 0;
        font-size: 0.85rem;
        padding: 0.55em 1em 0.55em 0.55em;
      }
      .chip__icon { width: 26px; height: 26px; }
    }

    .tours__grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1.5rem;
    }
    .card {
      background: var(--cream);
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      overflow: hidden;
      display: flex; flex-direction: column;
      transition: all 0.35s var(--ease);
      opacity: 0;
      transform: translateY(24px);
    }
    .card.is-visible {
      opacity: 1;
      transform: translateY(0);
      transition-delay: var(--delay, 0s);
    }
    .card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-md);
      border-color: var(--text-soft);
    }
    .card__media {
      position: relative;
      aspect-ratio: 16/10;
      overflow: hidden;
    }
    .card__media img {
      width: 100%; height: 100%; object-fit: cover;
      transition: transform 0.6s var(--ease);
    }
    .card:hover .card__media img { transform: scale(1.04); }
    .card__cat {
      position: absolute; top: 0.9rem; left: 0.9rem;
      display: inline-flex; align-items: center; gap: 0.4rem;
      padding: 0.35em 0.8em;
      background: rgba(254, 252, 247, 0.92);
      backdrop-filter: blur(8px);
      border-radius: 999px;
      font-size: 0.74rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      color: var(--text);
    }

    .card__body {
      padding: 1.4rem 1.4rem 1.2rem;
      display: flex; flex-direction: column; flex: 1;
    }
    .card__title {
      font-family: var(--font-display);
      font-size: 1.5rem;
      font-weight: 500;
      line-height: 1.15;
      color: var(--ink);
      margin-bottom: 0.35rem;
    }
    .card__subtitle {
      font-size: 0.88rem;
      color: var(--terracotta);
      
      margin-bottom: 0.9rem;
    }
    .card__desc {
      font-size: 0.92rem;
      color: var(--text-mute);
      line-height: 1.55;
      margin-bottom: 1rem;
    }
    .card__meta {
      display: flex; flex-wrap: wrap; gap: 0.9rem;
      font-size: 0.82rem; color: var(--text-soft);
      margin-top: auto;
      padding-top: 0.5rem;
    }
    .card__meta-item { display: inline-flex; align-items: center; gap: 0.35rem; }
    .card__extras {
      font-size: 0.78rem; color: var(--text-soft);
      
      margin-top: 0.5rem;
    }
    .card__footer {
      display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center;
      gap: 0.75rem;
      margin-top: 1.2rem;
      padding-top: 1rem;
      border-top: 1px solid var(--line);
    }
    .card__price {
      font-family: var(--font-display);
      font-size: 1.35rem;
      font-weight: 600;
      color: var(--ink);
    }
    .card__actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }

    /* ============ COUCH ============ */
    .couch {
      padding: clamp(3rem, 6vw, 5rem) 0;
      background: linear-gradient(135deg, var(--azure-deep) 0%, var(--azure) 100%);
      color: #fff;
    }
    .couch__inner {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 2.5rem;
      align-items: center;
      opacity: 0;
      transform: translateY(20px);
      transition: all 0.8s var(--ease);
    }
    .couch__inner.is-visible { opacity: 1; transform: translateY(0); }
    .couch__icon-wrap {
      width: 90px; height: 90px;
      display: grid; place-items: center;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.25);
      border-radius: 50%;
      flex-shrink: 0;
    }
    .couch .section-title { color: #fff; font-size: clamp(1.6rem, 1.2rem + 1.5vw, 2.4rem); }
    .couch .kicker { color: rgba(255, 240, 210, 0.85); }
    .couch__text p:last-child { color: rgba(255,255,255,0.85); }
    @media (max-width: 780px) {
      .couch__inner { grid-template-columns: 1fr; text-align: center; gap: 1.5rem; }
      .couch__icon-wrap { margin: 0 auto; }
    }

    /* ============ FORM ============ */
    .form-section { padding: clamp(4rem, 8vw, 7rem) 0; }
    .form-section__grid {
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: clamp(2rem, 5vw, 4.5rem);
      align-items: start;
      max-width: 1040px;
      margin: 0 auto;
    }
    .form-section__info { opacity: 0; transform: translateY(20px); transition: all 0.8s var(--ease); }
    .form-section__info.is-visible { opacity: 1; transform: translateY(0); }
    .form-section__lead {
      color: var(--text-mute);
      margin-bottom: 2rem;
      max-width: 420px;
    }
    .form-section__perks {
      list-style: none;
      display: flex; flex-direction: column;
      gap: 0.9rem;
    }
    .form-section__perks li {
      display: inline-flex; align-items: center; gap: 0.7rem;
      font-size: 0.92rem;
      color: var(--text);
    }

    .form {
      background: var(--cream);
      padding: clamp(1.5rem, 3vw, 2.2rem);
      border-radius: var(--radius-lg);
      border: 1px solid var(--line);
      box-shadow: var(--shadow-sm);
      opacity: 0;
      transform: translateY(20px);
      transition: all 0.8s var(--ease) 0.1s;
    }
    .form.is-visible { opacity: 1; transform: translateY(0); }
    .form__group { margin-bottom: 1.1rem; }
    .form__group label {
      display: block;
      font-size: 0.82rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      color: var(--text-mute);
      margin-bottom: 0.4rem;
    }
    .form__group input,
    .form__group select,
    .form__group textarea {
      width: 100%;
      font-family: var(--font-body);
      font-size: 1rem;
      padding: 0.75rem 0.9rem;
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: var(--radius-sm);
      color: var(--text);
      transition: border-color 0.2s, background 0.2s;
    }
    .form__group input:focus,
    .form__group select:focus,
    .form__group textarea:focus {
      outline: none;
      border-color: var(--azure);
      background: #fff;
    }
    .form__group textarea { resize: vertical; min-height: 100px; }
    @media (max-width: 780px) {
      .form-section__grid { grid-template-columns: 1fr; }
    }

    /* ============ CONTACT ============ */
    .contact { padding: clamp(4rem, 8vw, 6rem) 0; background: var(--paper); }
    .contact__grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1rem;
      margin-top: 2.5rem;
    }
    .contact__card {
      display: flex; flex-direction: column; gap: 0.4rem;
      padding: 1.4rem;
      background: var(--cream);
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      transition: all 0.25s var(--ease);
      opacity: 0;
      transform: translateY(16px);
    }
    .contact__card.is-visible { opacity: 1; transform: translateY(0); }
    .contact__card:hover {
      transform: translateY(-3px);
      border-color: var(--text);
      box-shadow: var(--shadow-sm);
    }
    .contact__icon {
      display: inline-flex;
      width: 32px; height: 32px;
      margin-bottom: 0.3rem;
    }
    .contact__icon svg { stroke: url(#grad-azure-terra); width: 100%; height: 100%; }
    .contact__label { font-size: 0.78rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-soft); }
    .contact__value { font-size: 0.95rem; color: var(--text); word-break: break-word; }
    .contact__card--whatsapp { border-color: rgba(37, 211, 102, 0.3); background: linear-gradient(135deg, var(--cream), #e8f7ec); }

    /* ============ FOOTER ============ */
    .footer {
      background: var(--ink);
      color: rgba(245, 239, 226, 0.85);
      padding: 4rem 0 1.5rem;
    }
    .footer__grid {
      display: grid;
      grid-template-columns: 1.4fr 1fr 1.2fr;
      gap: 3rem;
    }
    .footer__logo {
      font-family: var(--font-display);
      font-size: 1.6rem;
      font-weight: 500;
      color: #fff;
      margin-bottom: 0.3rem;
    }
    .footer__tagline { font-size: 0.88rem; opacity: 0.7; margin-bottom: 1.5rem; max-width: 300px; }
    .footer__social { display: flex; gap: 0.75rem; }
    .footer__social a {
      width: 40px; height: 40px;
      display: grid; place-items: center;
      border: 1px solid rgba(245, 239, 226, 0.2);
      border-radius: 50%;
      color: rgba(245, 239, 226, 0.85);
      transition: all 0.25s;
    }
    .footer__social a:hover {
      background: var(--terracotta);
      border-color: var(--terracotta);
      color: #fff;
    }
    .footer__social svg { width: 18px; height: 18px; }

    .footer__heading {
      font-family: var(--font-display);
      font-size: 1.1rem;
      color: #fff;
      margin-bottom: 1rem;
      font-weight: 500;
    }
    .footer__list { list-style: none; }
    .footer__list li { margin-bottom: 0.5rem; }
    .footer__list a { color: rgba(245, 239, 226, 0.8); font-size: 0.9rem; }
    .footer__list a:hover { color: #fff; }

    .footer__license {
      display: flex; gap: 1rem; align-items: center;
      color: rgba(245, 239, 226, 0.85);
      font-size: 0.78rem;
      line-height: 1.45;
    }
    .footer__license img {
      width: 96px; height: 96px;
      background: #fff;
      padding: 6px;
      border-radius: 8px;
      flex-shrink: 0;
    }
    .footer__license-url { margin-top: 0.3rem; opacity: 0.7; font-size: 0.7rem; word-break: break-all; }

    .footer__bottom {
      margin-top: 3rem;
      padding-top: 1.5rem;
      border-top: 1px solid rgba(245, 239, 226, 0.08);
      display: flex; justify-content: space-between; flex-wrap: wrap;
      gap: 1rem;
      font-size: 0.78rem;
      color: rgba(245, 239, 226, 0.55);
    }
    .footer__legal {  }

    @media (max-width: 780px) {
      .footer__grid { grid-template-columns: 1fr; gap: 2rem; }
    }

    /* ============ MODAL ============ */
    .modal {
      width: min(680px, 92vw);
      max-height: 88vh;
      border: none;
      border-radius: var(--radius-lg);
      padding: 0;
      background: var(--cream);
      box-shadow: var(--shadow-lg);
      color: var(--text);
      /* centering */
      margin: auto;
      inset: 0;
      /* entry/exit animation */
      opacity: 0;
      transform: translateY(16px) scale(0.96);
      transition:
        opacity 0.35s var(--ease),
        transform 0.35s var(--ease),
        overlay 0.35s var(--ease) allow-discrete,
        display 0.35s var(--ease) allow-discrete;
    }
    .modal[open] {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
    @starting-style {
      .modal[open] {
        opacity: 0;
        transform: translateY(16px) scale(0.96);
      }
    }
    .modal::backdrop {
      background: rgba(13, 74, 94, 0.6);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      opacity: 0;
      transition:
        opacity 0.35s var(--ease),
        overlay 0.35s var(--ease) allow-discrete,
        display 0.35s var(--ease) allow-discrete;
    }
    .modal[open]::backdrop { opacity: 1; }
    @starting-style {
      .modal[open]::backdrop { opacity: 0; }
    }

    /* Mobile: bottom sheet */
    @media (max-width: 720px) {
      .modal {
        width: 100%;
        max-width: 100%;
        margin: 0;
